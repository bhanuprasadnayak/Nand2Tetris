// File name: projects/1/Mux.hdl
/** 
 * Multiplexor:
 * if (sel = 0) out = a, else out = b
 */
CHIP MyMux {
    IN a, b, sel;
    OUT out;

    PARTS:
    MyNot(in=sel, out=notsel);
    MyAnd(a=a, b=notsel, out=out1);
    MyAnd(a=sel, b=b, out=out2);
    MyOr(a=out1, b=out2, out=out);

}
